# .gitignore

# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
build/
*.min.js

# Environment variables
.env
.env.local
.env.development
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
*.lcov

# IDE & Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Client specific
client/.env
client/dist/
client/build/
client/coverage/

# Server specific
server/uploads/
server/logs/
server/*.log

# Temporary folders
tmp/
temp/

# Database
*.sqlite
*.db

# Vercel / Render / Deployment
.vercel
.render

# Misc
*.env.example
package-lock.json.bak
yarn.lock.bak